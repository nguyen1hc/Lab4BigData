# Copy to ignored .env before the first Docker run. Never commit the real value.
REPO_ID=huggingface/optimum
SOURCE_REPO_PATH=./source-repo
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-with-a-local-secret
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=lab04
MONGODB_COLLECTION=source_metadata
CHECKPOINT_DIR=/opt/checkpoints/source-metadata-v1
